# Copy this file to .env before running the project.
#
# Minimum setup for the current example model list:
# - set OPENROUTER_API_KEY
# - keep the example models on OpenRouter in models.json
#
# Optional provider keys are only needed if you switch some models to the
# direct OpenAI or Anthropic provider adapters.

# OpenRouter API key.
# Required if you use the default example models.
OPENROUTER_API_KEY=

# OpenAI API key.
# Optional. Only required if a model in models.json uses provider = "openai".
OPENAI_API_KEY=

# Anthropic API key.
# Optional. Only required if a model in models.json uses provider = "anthropic".
ANTHROPIC_API_KEY=

# SQLite database path.
# A relative path is created in the project root.
STOCK_BENCH_DATABASE=stock_bench.db

# Number of executor rounds each model should accumulate before the pool stops
# being treated as bootstrap / provisional.
STOCK_BENCH_BOOTSTRAP_ROUNDS=8

# Minimum number of evaluator responses required to score a round.
# With 4 models in the pool, the practical maximum is 3.
STOCK_BENCH_MIN_EVALUATORS=3

# Fraction of rounds that should come from the small seed anchor set.
# 0.2 means roughly 20% anchor-style rounds and 80% general/generated rounds.
STOCK_BENCH_ANCHOR_RATIO=0.2

# Request timeout in seconds for provider calls.
STOCK_BENCH_REQUEST_TIMEOUT=60
